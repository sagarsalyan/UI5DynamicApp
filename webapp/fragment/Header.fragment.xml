<core:FragmentDefinition xmlns:layout="sap.ui.layout" xmlns="sap.m" xmlns:core="sap.ui.core">
	<layout:HorizontalLayout>
		<layout:VerticalLayout>
			<HBox>
				<Label text="Name:" class="sapMObjStatusText"/>
				<Label text="{headerModel>/name}" class="sapUiTinyMarginBegin"/>
			</HBox>
			<HBox>
				<Label text="Employee No:" class="sapMObjStatusText"/>
				<Label text="{headerModel>/empno}" class="sapUiTinyMarginBegin"/>
			</HBox>
			<HBox>
				<Label text="Employee Status:" class="sapMObjStatusText"/>
				<Label text="{headerModel>/stus}" class="sapUiTinyMarginBegin"/>
			</HBox>
		</layout:VerticalLayout>
	</layout:HorizontalLayout>
	<layout:HorizontalLayout>
		<layout:VerticalLayout>
			<HBox>
				<Label text="Department:" class="sapMObjStatusText"/>
				<Label text="{headerModel>/dept}" class="sapUiTinyMarginBegin"/>
			</HBox>
			<HBox>
				<Label text="Designation:" class="sapMObjStatusText"/>
				<Label text="{headerModel>/design}" class="sapUiTinyMarginBegin"/>
			</HBox>
			<HBox>
				<Label text="Office:" class="sapMObjStatusText"/>
				<Label text="{headerModel>/ofc}" class="sapUiTinyMarginBegin"/>
			</HBox>
		</layout:VerticalLayout>
	</layout:HorizontalLayout>
	<layout:HorizontalLayout>
		<layout:VerticalLayout>
			<HBox>
				<Label text="Email:" class="sapMObjStatusText"/>
				<Label text="{headerModel>/email}" class="sapUiTinyMarginBegin"/>
			</HBox>
			<HBox>
				<Label text="Mobile:" class="sapMObjStatusText"/>
				<Label text="{headerModel>/mobile}" class="sapUiTinyMarginBegin"/>
			</HBox>
		</layout:VerticalLayout>
	</layout:HorizontalLayout>
</core:FragmentDefinition>
